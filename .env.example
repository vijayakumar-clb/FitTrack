# ==============================================================================
# FitTrack Core Environment Configuration Template
# Copy this file to '.env' on your local system and update values securely.
# ==============================================================================

# 1. Application Runtime Settings
NODE_ENV=development
PORT=5000
API_VERSION=v1

# 2. Relational Database Credentials (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fittrack_db
DB_USER=fittrack_user
DB_PASSWORD=replace_with_a_secure_dev_password
DB_SSL=false

# 3. Cache & Session Store (Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=replace_with_a_secure_redis_password

# 4. End-to-End Cryptography Engine Flags
# The key must be a random, cryptographically secure 32-character string
ENCRYPTION_KEY=your_32_character_secret_key_here
ENCRYPTION_ALGORITHM=aes-256-gcm

# 5. Native Smart Device Integration Keys (Sandboxed)
APPLE_HEALTH_KIT_KEY=mock_sandbox_apple_key_dev
GOOGLE_FIT_API_KEY=mock_sandbox_google_fit_key_dev

# 6. Global Access Rules (CORS)
CORS_ORIGIN=http://localhost:3000,http://localhost:5000
